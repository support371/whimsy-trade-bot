# Public frontend values only (safe to expose in browser)
# These are Supabase anon/public credentials - NOT secrets

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key-here
VITE_SUPABASE_PROJECT_ID=your-project-id

# ============================================
# SERVER-ONLY VALUES - NEVER EXPOSE TO BROWSER
# ============================================
# Set these in Vercel Environment Variables, NOT in .env files
#
# SUPABASE_SERVICE_ROLE_KEY=
# EXCHANGE_API_KEY=
# EXCHANGE_API_SECRET=
# OPENAI_API_KEY=
# LOVABLE_API_KEY=
# DATABASE_URL=
# JWT_SECRET=
